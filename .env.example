# Holdsport credentials for fetching the team roster (scripts/fetch-roster.mjs).
# Copy this file to `.env` and fill in your values. `.env` is gitignored — it
# never goes to git. In production, set these as deploy/CI secrets instead.
#
# Don't know your team ID? Fill in email + password, then run: npm run roster:teams
HOLDSPORT_EMAIL=
HOLDSPORT_PASSWORD=
HOLDSPORT_TEAM_ID=
